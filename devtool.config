PROJECT=AIRDEV

# Environments
VALID_ENV_TARGETS=(local development production)
DEFAULT_ENV_TARGET=development
BASE_DB_ENV_TARGET=development

# 1Password
OP_ACCOUNT=airdev.1password.com

# Templates
ENV_TEMPLATE_PATH=scripts/env-templates
COMMON_ENV_OUTPUT_PATH=.env.local

# Databases
# Valid DATABASE_TYPE: 'none' | 'cockrach' | 'postgres'
DATABASE_TYPE=cockroach
DATABASE_URL_CMD="devtool cred get data.$ENV_CURRENT.databaseUrl"

# Databag (Optional)
DATABAG_JSON_PATH=databag.json
DATABAG_PASSWORD_VAR_NAME=DATABAG_PASSWORD

# Stripe (Optional)
STRIPE_WEBHOOK_URL=localhost:3000/api/webhooks/stripe
